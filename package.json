{
  "name": "ghostly",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @ghostly-io/runner --filter @ghostly-io/api run dev",
    "dev:api": "pnpm --filter @ghostly-io/api dev",
    "dev:web": "pnpm --filter @ghostly-io/web dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm --filter @ghostly-io/runner run typecheck && pnpm --filter @ghostly-io/api run typecheck && pnpm --filter @ghostly-io/mcp-server run typecheck && pnpm --filter @ghostly-io/scanner run typecheck && pnpm --filter @ghostly-io/web run typecheck",
    "start": "pnpm --filter @ghostly-io/api start",
    "pw:install": "pnpm --filter @ghostly-io/runner exec playwright install chromium",
    "mcp:build": "pnpm --filter @ghostly-io/mcp-server build",
    "publish-check": "pnpm --filter @ghostly-io/cli publish-check",
    "scan": "pnpm exec tsx packages/scanner/src/index.ts",
    "test:login-smoke": "pnpm exec tsx scripts/login-smoke-example.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
