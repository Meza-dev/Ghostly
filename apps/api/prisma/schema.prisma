generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  createdAt    DateTime @default(now())
  apiKeys      ApiKey[]
  projects     Project[]
  runs         Run[]
  memories     AssistMemory[]
  llmSettings  UserLlmSettings?

  @@map("users")
}

model UserLlmSettings {
  userId     String   @id
  providerId String
  model      String
  apiKey     String?
  baseUrl    String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_llm_settings")
}

model AssistMemory {
  id        String   @id @default(cuid())
  userId    String
  project   String
  baseUrl   String
  goal      String
  stepsJson String
  hits      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, project, baseUrl, goal])
  @@index([userId, project, updatedAt])
  @@map("assist_memories")
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  key       String   @unique
  label     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Project {
  id        String   @id @default(uuid())
  userId    String
  label     String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Run {
  id         String   @id @default(uuid())
  userId     String
  // status se mantiene por compatibilidad: "pass" | "fail" | "running"
  // (pass <=> verdict=success; fail <=> cualquier fail-*; inconclusive-* mapea a fail para clientes viejos)
  status     String
  // Taxonomia de veredictos (spec Sec.5) - fuente de verdad del desenlace.
  // Runs historicos quedan con verdict = null ("sin clasificar").
  verdict       String?
  // Reasoning del juez o descripcion del check determinista que resolvio el veredicto.
  verdictReason String?
  // stopReason interno del pipeline (packages/runner), hoy no persistido.
  stopReason    String?
  startedAt  DateTime @default(now())
  durationMs Int      @default(0)
  baseUrl    String
  project    String?
  contextId  String?
  videoPath  String?
  assistedMeta String?
  codeHintsJson String?
  steps      Step[]
  events     RunEvent[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("runs")
}

model RunEvent {
  id        String   @id @default(cuid())
  runId     String
  sequence  Int
  type      String
  stepIndex Int?
  payload   String
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, sequence])
  @@map("run_events")
}

model Step {
  id             Int     @id @default(autoincrement())
  runId          String
  index          Int
  action         String
  ok             Boolean
  error          String?
  screenshotPath String?
  a11y           String?
  run            Run     @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("steps")
}
